# =====================================================
# SBC Coaching Classes - Production Backend
# =====================================================

# ---- Server ----
PORT=5000
NODE_ENV=production

# ---- Supabase ----
# Set your Supabase project keys (used by backend)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_SERVICE_KEY=

# ---- JWT ----
JWT_SECRET=replace-this-with-a-very-long-random-string
JWT_EXPIRES_IN=7d
COOKIE_SECRET=replace-this-with-a-very-long-random-string

# ---- CORS / Frontend ----
FRONTEND_URL=http://localhost:5173

# ---- Email (optional, for OTP / receipts) ----
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM="SBC Classes <noreply@sbcclasses.com>"

# ---- Paytm UPI ----
# Replace with credentials from https://business.paytm.com
PAYTM_MID=YOUR_MID_HERE
PAYTM_KEY=YOUR_KEY_HERE
PAYTM_WEBSITE=WEBSTAGING
# Stage: https://securegw-stage.paytm.in   |   Prod: https://securegw.paytm.in
PAYTM_GATEWAY_URL=https://securegw-stage.paytm.in
PAYTM_INDUSTRY_TYPE=Retail
PAYTM_CHANNEL_ID=WEB
PAYTM_CALLBACK_URL=http://localhost:5000/api/paytm/callback

# ---- Bootstrap admin (used by `npm run create-admin`) ----
BOOTSTRAP_ADMIN_NAME=Super Admin
BOOTSTRAP_ADMIN_EMAIL=admin@sbcclasses.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeThisStrong#1

# ---- Logging ----
LOG_LEVEL=info
